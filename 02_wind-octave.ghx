                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""Provides a scripting component.
    Inputs:
        x: The x script variable
        y: The y script variable
    Output:
        a: The a output variable"""

import rhinoscriptsyntax as rs
import Rhino.Geometry as rg
import math

def get_gerstner_node(pt, t, amp, wl, st, angle_rad):
    """Compute the displacement of a single Gerstner wave."""
    if wl &lt;= 0: wl = 0.1
    k = 2 * math.pi / wl
    w = math.sqrt(9.8 * k)
    
    # Compute the direction vector
    dir_x = math.cos(angle_rad)
    dir_y = math.sin(angle_rad)
    
    # Project the distance onto that direction (core logic 1)
    dist = pt.X * dir_x + pt.Y * dir_y
    phase = k * dist - w * t
    
    dx = (st / k) * dir_x * math.sin(phase)
    dy = (st / k) * dir_y * math.sin(phase)
    dz = amp * math.cos(phase)
    
    return rg.Vector3d(dx, dy, dz)

def generate_ocean_wave(pts, t, amp, wavelength, steepness, n_intensity, n_scale, wind_dir, seed):
    if not pts: return []
    
    new_points = []
    angle_rad = math.radians(wind_dir)
    
    for i, p in enumerate(pts):
        pt = rg.Point3d(p)
        
        # [Logic 4] Noise masking (amplitude masking)
        # Determine the wave intensity at each point from its position and seed value
        noise = (math.sin(pt.X * n_scale + seed) * 
                 math.cos(pt.Y * n_scale * 0.9 + seed * 0.5))
        mask = (noise + 1.0) * 0.5 * n_intensity # normalize to the 0-1 range
        
        # [Logic 2] Octave layering
        # Layer 1: large swell (base wave)
        disp1 = get_gerstner_node(pt, t, amp, wavelength, steepness, angle_rad)
        
        # Layer 2: small ripples (detail wave) - wavelength 1/3, amplitude 30%, angle offset by 15 degrees
        detail_amp = amp * 0.3 * mask
        detail_wl = wavelength * 0.35
        detail_angle = angle_rad + math.radians(15.0) # slight angle offset (logic 3)
        disp2 = get_gerstner_node(pt, t, detail_amp, detail_wl, steepness * 0.5, detail_angle)
        
        # Sum the final displacement (mask applied)
        final_dz = (disp1.Z + disp2.Z) * (1.0 + mask)
        final_dx = (disp1.X + disp2.X)
        final_dy = (disp1.Y + disp2.Y)
        
        new_points.append(rg.Point3d(pt.X - final_dx, pt.Y - final_dy, pt.Z + final_dz))
        
    return new_points

# --- Output ---
a = generate_ocean_wave(pts, t, amp, wavelength, steepness, n_intensity, n_scale, wind_dir, seed)</item>
