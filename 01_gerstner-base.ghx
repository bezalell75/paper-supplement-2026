                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""Provides a scripting component.
    Inputs:
        x: The x script variable
        y: The y script variable
    Output:
        a: The a output variable"""

import rhinoscriptsyntax as rs
import Rhino.Geometry as rg
import math

def generate_natural_wave_2d(pts, t, amp, wavelength, steepness, n_intensity, n_scale):
    if not pts: return []
    new_points = []
    
    if wavelength &lt;= 0: wavelength = 0.1
    k = 2 * math.pi / wavelength
    w = math.sqrt(9.8 * k) 
    
    for p in pts:
        pt = rg.Point3d(p)
        x0, y0 = pt.X, pt.Y
        
        # 1. Mathematical noise (modified so that X and Y are mixed together)
        # Interfere the X and Y phases differently to avoid a grid-like pattern.
        noise = (math.sin(x0 * n_scale + t * 0.5) * 
                 math.cos(y0 * n_scale * 1.2 + t * 0.4) + 
                 math.sin((x0 + y0) * n_scale * 0.7 + t * 0.2))
        
        # 2. Compute the composite XY phase
        # Include both x0 and y0 so the wave spreads diagonally and in multiple directions.
        # Coefficients such as 0.7 and 0.5 make the X- and Y-axis wave periods slightly different.
        phase_x = k * x0 - w * t + (noise * 0.5)
        phase_y = k * y0 - w * t * 0.8 + (noise * 0.5) # the Y-axis moves at a slightly different speed
        
        # 3. Apply Gerstner wave displacement (deform X, Y and Z)
        # Compute both horizontal displacements (dx, dy) so particles converge in all directions.
        dx = (steepness / k) * math.sin(phase_x)
        dy = (steepness / k) * math.sin(phase_y)
        
        # Vertical displacement (dz): apply the interference between the X-wave and Y-wave.
        dz = (amp + noise * n_intensity) * (math.cos(phase_x) + math.cos(phase_y)) * 0.5
        
        # 4. Build the final point (add dz to the original Z value)
        new_pt = rg.Point3d(x0 - dx, y0 - dy, pt.Z + dz)
        new_points.append(new_pt)
        
    return new_points

# --- Output ---
a = generate_natural_wave_2d(pts, t, amp, wavelength, steepness, n_intensity, n_scale)</item>
