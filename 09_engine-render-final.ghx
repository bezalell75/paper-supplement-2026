                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""Provides a scripting component.
    Inputs:
        x: The x script variable
        y: The y script variable
    Output:
        a: The a output variable"""

import rhinoscriptsyntax as rs
import Rhino.Geometry as rg
import math

def get_gerstner_node(pt, t, amp, wl, st, angle_rad):
    """Compute the displacement of a single Gerstner wave."""
    if wl &lt;= 0: wl = 0.1
    k = 2 * math.pi / wl
    w = math.sqrt(9.8 * k)
    
    dir_x = math.cos(angle_rad)
    dir_y = math.sin(angle_rad)
    
    # [Logic 2 extension] Compute distance based on the warped coordinates
    dist = pt.X * dir_x + pt.Y * dir_y
    phase = k * dist - w * t
    
    dx = (st / k) * dir_x * math.sin(phase)
    dy = (st / k) * dir_y * math.sin(phase)
    dz = amp * math.cos(phase)
    
    return rg.Vector3d(dx, dy, dz)

def generate_ultimate_ocean(pts, t, amp, wavelength, steepness, n_intensity, n_scale, wind_dir, seed, falloff, lean, turbulence, spread, energy_decay, freq_step, clumping, warp):
    if not pts: return []
    
    new_points = []
    main_angle = math.radians(wind_dir)
    
    # Compute the spatial center point and extents
    bbox = rg.BoundingBox(pts)
    center = bbox.Center
    dim_x = bbox.Max.X - bbox.Min.X
    max_dist = center.DistanceTo(bbox.Min)
    
    for p in pts:
        pt = rg.Point3d(p)
        
        # --- Macro logic 1: Domain warping ---
        # Twist the coordinates with noise to bend the wave travel direction.
        warp_noise = math.sin(pt.Y * (5.0 / dim_x) + seed) * warp
        warped_pt = rg.Point3d(pt.X + warp_noise, pt.Y + warp_noise, pt.Z)
        
        # --- Macro logic 2: Energy clumping (wave clumping) ---
        # Create large-scale energy variation across the whole plate
        clump_map = (math.sin(pt.X * (3.0 / dim_x) + seed) * 
                     math.cos(pt.Y * (3.0 / dim_x) + seed * 0.5))
        clump_factor = 1.0 - (clumping * (clump_map * 0.5 + 0.5))
        
        # 1. Spatial damping and turbulence
        dist_to_center = pt.DistanceTo(center)
        fade = math.pow(max(0, 1.0 - (dist_to_center / max_dist)), falloff)
        turb = (math.sin(pt.X * 5.0 + t) * math.cos(pt.Y * 5.0 + seed)) * turbulence
        
        # 2. Intelligent 5-octave accumulation (using warped coordinates)
        total_disp = rg.Vector3d(0, 0, 0)
        current_amp = amp * clump_factor # apply the clumped amplitude
        current_wl = wavelength
        golden_angle = 2.399 
        
        for i in range(5):
            angle_offset = (i * golden_angle * spread)
            l_ang = main_angle + angle_offset
            
            # pass the warped coordinates (warped_pt) to refract the flow
            total_disp += get_gerstner_node(warped_pt, t, current_amp, current_wl, steepness, l_ang)
            
            current_amp *= energy_decay
            current_wl /= freq_step
            
        # 3. Global masking
        total_disp *= (fade + turb + (n_intensity * 0.1))
        
        # 4. Nonlinear lean
        lean_amount = math.pow(max(0, total_disp.Z / (amp + 0.1)), 2) * lean * fade
        
        # Compose the final point
        final_x = pt.X - total_disp.X - (math.cos(main_angle) * lean_amount)
        final_y = pt.Y - total_disp.Y - (math.sin(main_angle) * lean_amount)
        final_z = pt.Z + total_disp.Z
        
        new_points.append(rg.Point3d(final_x, final_y, final_z))
        
    return new_points

# --- Output ---
a = generate_ultimate_ocean(pts, t, amp, wavelength, steepness, n_intensity, n_scale, wind_dir, seed, falloff, lean, turbulence, spread, energy_decay, freq_step, clumping, warp)</item>
